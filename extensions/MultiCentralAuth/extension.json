{
	"name": "MultiCentralAuth",
	"version": "1.0.0",
	"author": "Jules",
	"url": "https://www.mediawiki.org/wiki/Extension:MultiCentralAuth",
	"descriptionmsg": "multicentralauth-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "specialpage",
	"requires": {
		"MediaWiki": ">= 1.45.1"
	},
	"GroupPermissions": {
		"user": {
			"ca-request": true,
			"ca-manage": true,
			"ca-request-view": true
		},
		"sysop": {
			"ca-merge": true,
			"ca-manage": true,
			"ca-admin": true,
			"ca-request-view": true
		}
	},
	"SpecialPages": {
		"CentralAuth": {
			"class": "MediaWiki\\Extension\\MultiCentralAuth\\Special\\SpecialCentralAuth",
			"services": [
				"ConnectionProvider",
				"UserFactory",
				"UserNameUtils",
				"MultiCentralAuth.ExternalCAProvider",
				"UserGroupManager",
				"BlockManager"
			]
		},
		"CentralAuthMerge": {
			"class": "MediaWiki\\Extension\\MultiCentralAuth\\Special\\SpecialCentralAuthMerge",
			"services": [
				"ConnectionProvider",
				"UserNameUtils",
				"MultiCentralAuth.ExternalCAProvider"
			]
		},
		"CentralAuthUnmerge": {
			"class": "MediaWiki\\Extension\\MultiCentralAuth\\Special\\SpecialCentralAuthUnmerge",
			"services": [
				"ConnectionProvider",
				"UserNameUtils"
			]
		},
		"ManageCA": {
			"class": "MediaWiki\\Extension\\MultiCentralAuth\\Special\\SpecialManageCA",
			"services": [
				"ConnectionProvider",
				"MultiCentralAuth.ExternalCAProvider",
				"UserGroupManager",
				"BlockManager",
				"UserFactory"
			]
		},
		"CAMergeRequest": {
			"class": "MediaWiki\\Extension\\MultiCentralAuth\\Special\\SpecialCAMergeRequest",
			"services": [
				"ConnectionProvider",
				"MultiCentralAuth.ExternalCAProvider"
			]
		},
		"CAMergeRequestQueue": {
			"class": "MediaWiki\\Extension\\MultiCentralAuth\\Special\\SpecialCAMergeRequestQueue",
			"services": [
				"ConnectionProvider",
				"UserFactory"
			]
		},
		"CentralAuthSettings": {
			"class": "MediaWiki\\Extension\\MultiCentralAuth\\Special\\SpecialCentralAuthSettings",
			"services": [
				"ConnectionProvider"
			]
		}
	},
	"MessagesDirs": {
		"MultiCentralAuth": [
			"i18n"
		]
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\MultiCentralAuth\\": "includes/"
	},
	"ResourceModules": {
		"ext.multicentralauth.styles": {
			"styles": "resources/main.less"
		},
		"ext.multicentralauth.js": {
			"scripts": "resources/ext.multicentralauth.js",
			"dependencies": [
				"mediawiki.util"
			],
			"messages": [
				"centralauth-merge-method-primary",
				"centralauth-merge-method-primary-desc",
				"centralauth-merge-method-new",
				"centralauth-merge-method-new-desc",
				"centralauth-merge-method-empty",
				"centralauth-merge-method-empty-desc",
				"centralauth-merge-method-password",
				"centralauth-merge-method-password-desc",
				"centralauth-merge-method-mail",
				"centralauth-merge-method-mail-desc",
				"centralauth-merge-method-admin",
				"centralauth-merge-method-admin-desc",
				"centralauth-merge-method-login",
				"centralauth-merge-method-login-desc"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteExtPath": "MultiCentralAuth"
	},
	"ServiceWiringFiles": [
		"includes/ServiceWiring.php"
	],
	"LogTypes": [
		"mca-log"
	],
	"LogNames": {
		"mca-log": "mca-log-name"
	},
	"LogHeaders": {
		"mca-log": "mca-log-header"
	},
	"LogActionsHandlers": {
		"mca-log/merge": "LogFormatter",
		"mca-log/unmerge": "LogFormatter",
		"mca-log/manage-add": "LogFormatter",
		"mca-log/manage-remove": "LogFormatter"
	},
	"Hooks": {
		"LoadExtensionSchemaUpdates": "MediaWiki\\Extension\\MultiCentralAuth\\Hooks::onLoadExtensionSchemaUpdates",
		"ContributionsToolLinks": "MediaWiki\\Extension\\MultiCentralAuth\\Hooks::onContributionsToolLinks",
		"MCAMergeRequestSubmitted": "MediaWiki\\Extension\\MultiCentralAuth\\Hooks::onMCAMergeRequestSubmitted",
		"MCAMergeRequestResolved": "MediaWiki\\Extension\\MultiCentralAuth\\Hooks::onMCAMergeRequestResolved"
	},
	"EchoNotifications": {
		"mca-merge-request-submitted": {
			"primary-link": {
				"message": "mca-notification-merge-request-submitted-link",
				"destination": "title"
			},
			"presentation-model": "MediaWiki\\Extension\\MultiCentralAuth\\MCAMergeRequestPresentationModel",
			"category": "mca-merge-request",
			"group": "positive",
			"icon": "mca-icon"
		},
		"mca-merge-request-resolved": {
			"primary-link": {
				"message": "mca-notification-merge-request-resolved-link",
				"destination": "title"
			},
			"presentation-model": "MediaWiki\\Extension\\MultiCentralAuth\\MCAMergeRequestPresentationModel",
			"category": "mca-merge-request",
			"group": "positive",
			"icon": "mca-icon"
		}
	},
	"EchoNotificationCategories": {
		"mca-merge-request": {
			"priority": 3,
			"tooltip": "echo-category-title-mca-merge-request"
		}
	},
	"EchoNotificationIcons": {
		"mca-icon": {
			"path": "MultiCentralAuth/resources/icons/merged-primary.png"
		}
	},
	"DefaultUserOptions": {
		"echo-subscriptions-email-mca-merge-request": true,
		"echo-subscriptions-web-mca-merge-request": true
	},
	"AvailableRights": [
		"ca-merge",
		"ca-manage",
		"ca-request",
		"ca-admin",
		"ca-request-view"
	],
	"manifest_version": 2
}
