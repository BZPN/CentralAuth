{
	"name": "MultiCentralAuth",
	"version": "1.0.0",
	"author": "Jules",
	"url": "https://www.mediawiki.org/wiki/Extension:MultiCentralAuth",
	"descriptionmsg": "multicentralauth-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "specialpage",
	"requires": {
		"MediaWiki": ">= 1.45.1"
	},
	"AvailableRights": [
		"ca-merge",
		"ca-manage"
	],
	"GroupPermissions": {
		"sysop": {
			"ca-merge": true,
			"ca-manage": true
		}
	},
	"SpecialPages": {
		"CentralAuth": {
			"class": "MediaWiki\\Extension\\MultiCentralAuth\\Special\\SpecialCentralAuth",
			"services": [
				"ConnectionProvider",
				"UserFactory",
				"UserNameUtils",
				"MultiCentralAuth.ExternalCAProvider",
				"UserGroupManager",
				"BlockManager"
			]
		},
		"CentralAuthMerge": {
			"class": "MediaWiki\\Extension\\MultiCentralAuth\\Special\\SpecialCentralAuthMerge",
			"services": [
				"ConnectionProvider",
				"UserNameUtils"
			]
		},
		"CentralAuthUnmerge": {
			"class": "MediaWiki\\Extension\\MultiCentralAuth\\Special\\SpecialCentralAuthUnmerge",
			"services": [
				"ConnectionProvider",
				"UserNameUtils"
			]
		},
		"ManageCA": {
			"class": "MediaWiki\\Extension\\MultiCentralAuth\\Special\\SpecialManageCA",
			"services": [
				"ConnectionProvider"
			]
		}
	},
	"MessagesDirs": {
		"MultiCentralAuth": [
			"i18n"
		]
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\MultiCentralAuth\\": "includes/"
	},
	"ResourceModules": {
		"ext.multicentralauth.styles": {
			"styles": "resources/main.less"
		},
		"ext.multicentralauth.js": {
			"scripts": "resources/ext.multicentralauth.js",
			"dependencies": [
				"mediawiki.util"
			],
			"messages": [
				"centralauth-merge-method-primary",
				"centralauth-merge-method-primary-desc",
				"centralauth-merge-method-new",
				"centralauth-merge-method-new-desc",
				"centralauth-merge-method-empty",
				"centralauth-merge-method-empty-desc",
				"centralauth-merge-method-password",
				"centralauth-merge-method-password-desc",
				"centralauth-merge-method-mail",
				"centralauth-merge-method-mail-desc",
				"centralauth-merge-method-admin",
				"centralauth-merge-method-admin-desc",
				"centralauth-merge-method-login",
				"centralauth-merge-method-login-desc"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteExtPath": "MultiCentralAuth"
	},
	"ServiceWiringFiles": [
		"includes/ServiceWiring.php"
	],
	"Hooks": {
		"LoadExtensionSchemaUpdates": "MediaWiki\\Extension\\MultiCentralAuth\\Hooks::onLoadExtensionSchemaUpdates"
	},
	"manifest_version": 2
}
